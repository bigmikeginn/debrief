EMBEDDING_MODEL=openai/text-embedding-3-small
PARSE_REFINER_SECRET=
PARSE_REFINER_BATCH_SIZE=10
PARSE_REFINER_MAX_ATTEMPTS=3
MAX_DEBRIEFS_PER_USER_PER_DAY=10
MAX_INPUT_CHARS=1200
DEBRIEF_COMMAND=#debrief

