# Required for automated beta-v1 rollout
SUPABASE_ACCESS_TOKEN=
SUPABASE_PROJECT_REF=
SUPABASE_DB_PASSWORD=

# Required app/provider secrets
OPENROUTER_API_KEY=
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_SECRET=

# Optional tuning
# Initial parse (telegram-webhook pass0)
MODEL_PRIMARY=google/gemini-2.0-flash-001
MODEL_FALLBACK=meta-llama/llama-3.1-8b-instruct
MODEL_CHAIN=
# Refinement pass (parse-refiner stage 1+2)
