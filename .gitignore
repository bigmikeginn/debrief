supabase/.temp/

# Environment files with secrets
.env
.env.*
beta-v1/.env.beta
!beta-v1/.env.beta.example

# Playwright test artifacts
.playwright-cli/
test-results/

# Node
node_modules/

# OS files
Thumbs.db
.DS_Store

# Editor config (optional, keep .vscode/settings.json if useful)
*.swp
*.swo
*~

# Ignore versioned bundles (built by build.sh)
# Keep unminified source files (.20260430g) for comparison during development
debrief-viewer.[a-f0-9]*.js
debrief-viewer.[a-f0-9]*.css
login-fallback.[a-f0-9]*.js
!debrief-viewer.20260430g.js
!debrief-viewer.20260430g.css
!login-fallback.20260430g.js
# Keep current production versions to ensure Vercel can deploy without building
!debrief-viewer.57eac966.js
!debrief-viewer.64852707.css
!login-fallback.3b75c387.js
# Keep latest minified versions (deployed to production)
!debrief-viewer.36c808a4.js
!debrief-viewer.59924d12.css
!login-fallback.92d54de8.js

# Deploy manifest (generated by build.sh)
deploy-manifest.json
!deploy-manifest.json
